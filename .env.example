# Penpot MCP credentials – used by the "penpot" MCP server in .mcp.json so AI
# agents (Claude Code, Cursor, etc.) can read the Trufos designs from Penpot.
#
# Copy this file to .env and fill in your own Penpot login. .env is gitignored;
# never commit real credentials. Prefer a dedicated read-only Penpot account.
#
# The Penpot instance URL is set in .mcp.json (https://penpot.soulka.de/api).

PENPOT_USERNAME=your-penpot-email
PENPOT_PASSWORD=your-penpot-password
