{
  "compilerOptions": {
    "target": "ES2024",
    "strict": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "lib": ["ESNext", "dom"],
    "paths": {
      "@/*": ["./src/renderer/*"],
      "main/*": ["./src/main/*"],
      "shim/*": ["./src/shim/*"]
    }
  },
  "include": ["src/**/*"]
}
