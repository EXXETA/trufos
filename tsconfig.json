{
  "compilerOptions": {
    "target": "ES2023",
    "allowJs": true,
    "module": "nodenext",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "outDir": "dist",
    "moduleResolution": "nodenext",
    "resolveJsonModule": true,
    "paths": {
      "@/*": ["./src/renderer/*"],
      "main/*": ["./src/main/*"],
      "shim/*": ["./src/shim/*"]
    },
    "jsx": "react-jsx",
    "lib": ["ESNext", "dom"]
  },
  "include": ["src/**/*"]
}
